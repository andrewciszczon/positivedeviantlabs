<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PDL Deliverables</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --navy:       #0d1b2a;
    --navy-mid:   #1a2e42;
    --navy-light: #243d56;
    --amber:      #c17f24;
    --amber-light:#e09b3d;
    --teal:       #004d50;
    --teal-accent:#00a8ae;
    --text-light: #e8e0d4;
    --text-muted: #8fa3b0;
    --border:     rgba(193,127,36,0.25);
    --tab-radius: 4px;
    --font:       'Inter', sans-serif;
  }

  body {
    font-family: var(--font);
    background: transparent;
    color: var(--text-light);
    padding: 0;
    margin: 0;
  }

  .pdl-tabs-wrapper {
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  /* --- Tab Nav --- */
  .pdl-tab-nav {
    display: flex;
    align-items: stretch;
    background: var(--navy-mid);
    border-bottom: 1px solid var(--border);
    padding: 0 4px;
    gap: 2px;
  }

  .pdl-tab-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 14px 12px;
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    color: var(--text-muted);
    font-family: var(--font);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    line-height: 1.3;
    text-align: center;
  }

  .pdl-tab-btn .tab-icon {
    font-size: 16px;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .pdl-tab-btn:hover {
    color: var(--amber-light);
    background: rgba(193,127,36,0.06);
  }

  .pdl-tab-btn:hover .tab-icon {
    transform: translateY(-1px);
  }

  .pdl-tab-btn.active {
    color: var(--amber-light);
    border-bottom-color: var(--amber);
    background: rgba(193,127,36,0.08);
  }

  /* --- Tab Label + Download Row --- */
  .pdl-tab-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    background: var(--navy-light);
    border-bottom: 1px solid var(--border);
  }

  .pdl-tab-title {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .pdl-tab-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
    font-weight: 400;
  }

  .pdl-download-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--teal-accent);
    text-decoration: none;
    letter-spacing: 0.04em;
    border: 1px solid rgba(0,168,174,0.3);
    padding: 6px 12px;
    border-radius: 3px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pdl-download-link:hover {
    background: rgba(0,168,174,0.1);
    border-color: var(--teal-accent);
    color: #fff;
  }

  .pdl-download-link svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* --- Tab Panels --- */
  .pdl-tab-panel {
    display: none;
  }

  .pdl-tab-panel.active {
    display: block;
  }

  .pdl-iframe-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    background: var(--navy);
  }

  .pdl-iframe-wrap iframe {
    display: block;
    width: 100%;
    height: 850px;
    border: none;
  }

  /* --- Mobile note --- */
  .pdl-mobile-note {
    display: none;
    padding: 12px 24px;
    background: rgba(193,127,36,0.08);
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .pdl-tab-btn {
      font-size: 10px;
      padding: 12px 6px;
    }
    .pdl-tab-btn .tab-icon {
      font-size: 14px;
    }
    .pdl-tab-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      padding: 14px 16px;
    }
    .pdl-mobile-note {
      display: block;
    }
  }
</style>
</head>
<body>

<div class="pdl-tabs-wrapper">

  <!-- Tab Navigation -->
  <nav class="pdl-tab-nav" role="tablist" aria-label="Crestline Deliverables">
    <button
      class="pdl-tab-btn active"
      role="tab"
      aria-selected="true"
      aria-controls="panel-current"
      id="tab-current"
      onclick="switchTab('current')"
    >
      <span class="tab-icon">◎</span>
      Current State
    </button>
    <button
      class="pdl-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="panel-future"
      id="tab-future"
      onclick="switchTab('future')"
    >
      <span class="tab-icon">◈</span>
      Future State
    </button>
    <button
      class="pdl-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="panel-roadmap"
      id="tab-roadmap"
      onclick="switchTab('roadmap')"
    >
      <span class="tab-icon">◇</span>
      Roadmap
    </button>
  </nav>

  <!-- Current State Panel -->
  <div class="pdl-tab-panel active" id="panel-current" role="tabpanel" aria-labelledby="tab-current">
    <div class="pdl-tab-header">
      <div>
        <div class="pdl-tab-title">Current State Assessment</div>
        <div class="pdl-tab-desc">Process map · Tech stack · Data flow · Org & budget — documented as-found, gaps included</div>
      </div>
      <a
        class="pdl-download-link"
        href="https://andrewciszczon.github.io/positivedeviantlabs/crestline_current_state.pdf"
        target="_blank"
        rel="noopener"
        aria-label="Download Current State PDF"
      >
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download PDF
      </a>
    </div>
    <div class="pdl-iframe-wrap">
      <iframe
        src="https://andrewciszczon.github.io/positivedeviantlabs/crestline_current_state_v4.html"
        title="Crestline Auto Group — Current State Assessment"
        loading="lazy"
      ></iframe>
    </div>
    <div class="pdl-mobile-note">
      Not optimized for mobile — download the PDF for a better experience on smaller screens.
    </div>
  </div>

  <!-- Future State Panel -->
  <div class="pdl-tab-panel" id="panel-future" role="tabpanel" aria-labelledby="tab-future">
    <div class="pdl-tab-header">
      <div>
        <div class="pdl-tab-title">Future State Design</div>
        <div class="pdl-tab-desc">The same four views, rebuilt around the strategy — where Crestline is headed and what changes to get there</div>
      </div>
      <a
        class="pdl-download-link"
        href="https://andrewciszczon.github.io/positivedeviantlabs/crestline_future_state.pdf"
        target="_blank"
        rel="noopener"
        aria-label="Download Future State PDF"
      >
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download PDF
      </a>
    </div>
    <div class="pdl-iframe-wrap">
      <iframe
        src="https://andrewciszczon.github.io/positivedeviantlabs/crestline_future_state_v2.html"
        title="Crestline Auto Group — Future State Design"
        loading="lazy"
      ></iframe>
    </div>
    <div class="pdl-mobile-note">
      Not optimized for mobile — download the PDF for a better experience on smaller screens.
    </div>
  </div>

  <!-- Roadmap Panel -->
  <div class="pdl-tab-panel" id="panel-roadmap" role="tabpanel" aria-labelledby="tab-roadmap">
    <div class="pdl-tab-header">
      <div>
        <div class="pdl-tab-title">Strategic Roadmap</div>
        <div class="pdl-tab-desc">Nine initiatives · Two phases · Owner, timeline, and dependencies mapped for each</div>
      </div>
      <a
        class="pdl-download-link"
        href="https://andrewciszczon.github.io/positivedeviantlabs/crestline_roadmap.pdf"
        target="_blank"
        rel="noopener"
        aria-label="Download Roadmap PDF"
      >
        <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2v8m0 0L5 7m3 3l3-3M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Download PDF
      </a>
    </div>
    <div class="pdl-iframe-wrap">
      <iframe
        src="https://andrewciszczon.github.io/positivedeviantlabs/crestline_roadmap_v1.html"
        title="Crestline Auto Group — Strategic Roadmap"
        loading="lazy"
      ></iframe>
    </div>
    <div class="pdl-mobile-note">
      Not optimized for mobile — download the PDF for a better experience on smaller screens.
    </div>
  </div>

</div>

<script>
  function switchTab(name) {
    // Deactivate all
    document.querySelectorAll('.pdl-tab-btn').forEach(btn => {
      btn.classList.remove('active');
      btn.setAttribute('aria-selected', 'false');
    });
    document.querySelectorAll('.pdl-tab-panel').forEach(panel => {
      panel.classList.remove('active');
    });

    // Activate selected
    const btn = document.getElementById('tab-' + name);
    const panel = document.getElementById('panel-' + name);
    if (btn) {
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
    }
    if (panel) {
      panel.classList.add('active');
    }
  }

  // Keyboard navigation for accessibility
  document.querySelectorAll('.pdl-tab-btn').forEach((btn, index, btns) => {
    btn.addEventListener('keydown', (e) => {
      let target = null;
      if (e.key === 'ArrowRight') target = btns[(index + 1) % btns.length];
      if (e.key === 'ArrowLeft') target = btns[(index - 1 + btns.length) % btns.length];
      if (target) { target.focus(); target.click(); }
    });
  });
</script>

</body>
</html>
